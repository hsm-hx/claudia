# ============================================================
# Claude Code Usage Monitor — Environment Variables
# ============================================================

# --- Required ---

# Anthropic API key (from console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Discord Webhook URL
# Create: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# --- Optional ---

# Monthly budget cap in USD (used to calculate % remaining)
# Default: 100.0
MONTHLY_BUDGET_USD=100.0

# Day of month when your Anthropic billing period resets (1–28)
# Default: 1 (1st of each month)
BILLING_CYCLE_DAY=1

# Override the Anthropic usage API path if your plan uses a different endpoint
# Default: /v1/usage
# Example for org plans:
#   ANTHROPIC_USAGE_PATH=/v1/organizations/YOUR_ORG_ID/usage
ANTHROPIC_USAGE_PATH=/v1/usage

# Cloud Run port (set automatically by Cloud Run; leave as-is)
PORT=8080

# --- GCP deployment (for deploy.sh) ---
GCP_PROJECT=your-gcp-project-id
GCP_REGION=asia-northeast1
