# ============================================================
# Claude Code Usage Monitor — Environment Variables
# ============================================================

# --- Required ---

# Discord Webhook URL
# Create: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# GitHub Personal Access Token（repo の read 権限が必要）
# https://github.com/settings/tokens → Fine-grained → Actions: Read
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx

# 監視するリポジトリ（カンマ区切り）
GITHUB_REPOS=owner/repo1,owner/repo2

# --- Optional ---

# 4時間ウィンドウあたりのコスト上限 USD（目安値。actual_cost_usd を見ながら調整）
# デフォルト: 5.0
MAX_COST_4H_USD=5.0

# 残り何%以下でアラートを送るか（デフォルト: 25）
LOW_THRESHOLD_PCT=25
